model ConsolidationGroup {
  id                 String                     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code               String                     @unique @db.VarChar(20)
  name               String                     @db.VarChar(150)
  reportingCurrency  CurrencyCode               @map("reporting_currency")
  ownerCompanyId     String?                    @map("owner_company_id") @db.Uuid
  isActive           Boolean                    @default(true) @map("is_active")
  createdAt          DateTime                   @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime                   @updatedAt @map("updated_at") @db.Timestamptz(6)
  ownerCompany       Company?                   @relation(fields: [ownerCompanyId], references: [id], onDelete: SetNull)
  companies          ConsolidationGroupCompany[]
  accountMaps        ConsolidationAccountMap[]
  runs               ConsolidationRun[]

  @@map("consolidation_groups")
}

model ConsolidationGroupCompany {
  id                  String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  groupId             String               @map("group_id") @db.Uuid
  companyId           String               @map("company_id") @db.Uuid
  consolidationMethod ConsolidationMethod  @map("consolidation_method")
  ownershipPercentage Decimal              @map("ownership_percentage") @db.Decimal(5, 2)
  effectiveFrom       DateTime             @map("effective_from") @db.Date
  effectiveTo         DateTime?            @map("effective_to") @db.Date
  createdAt           DateTime             @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt           DateTime             @updatedAt @map("updated_at") @db.Timestamptz(6)
  group               ConsolidationGroup   @relation(fields: [groupId], references: [id], onDelete: Cascade)
  company             Company              @relation(fields: [companyId], references: [id], onDelete: Restrict)

  @@unique([groupId, companyId, effectiveFrom], map: "uq_consolidation_group_companies_period")
  @@index([companyId], map: "idx_consolidation_group_companies_company")
  @@map("consolidation_group_companies")
}

model ConsolidationAccountMap {
  id                  String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  groupId             String             @map("group_id") @db.Uuid
  companyId           String             @map("company_id") @db.Uuid
  sourceAccountId     String             @map("source_account_id") @db.Uuid
  targetAccountCode   String             @map("target_account_code") @db.VarChar(30)
  createdAt           DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt           DateTime           @updatedAt @map("updated_at") @db.Timestamptz(6)
  group               ConsolidationGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  company             Company            @relation(fields: [companyId], references: [id], onDelete: Restrict)
  sourceAccount       ChartAccount       @relation(fields: [sourceAccountId], references: [id], onDelete: Restrict)

  @@unique([groupId, companyId, sourceAccountId], map: "uq_consolidation_account_maps_source")
  @@index([groupId, targetAccountCode], map: "idx_consolidation_account_maps_target")
  @@map("consolidation_account_maps")
}

model ConsolidationRun {
  id               String                  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  groupId          String                  @map("group_id") @db.Uuid
  runName          String                  @map("run_name") @db.VarChar(60)
  periodStart      DateTime                @map("period_start") @db.Date
  periodEnd        DateTime                @map("period_end") @db.Date
  status           ConsolidationRunStatus  @default(DRAFT)
  initiatedByUserId String?                @map("initiated_by_user_id") @db.Uuid
  approvedByUserId String?                 @map("approved_by_user_id") @db.Uuid
  initiatedAt      DateTime                @default(now()) @map("initiated_at") @db.Timestamptz(6)
  approvedAt       DateTime?               @map("approved_at") @db.Timestamptz(6)
  createdAt        DateTime                @default(now()) @map("created_at") @db.Timestamptz(6)
