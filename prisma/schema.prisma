enum CurrencyCode {
  ARS
  USD
  EUR
  BRL
  CLP
  UYU
}

enum UserRole {
  SUPERADMIN
  ADMIN
  ACCOUNTANT
  AUDITOR
  VIEWER
}

enum AccountType {
  ASSET
  LIABILITY
  EQUITY
  REVENUE
  EXPENSE
  MEMORANDUM
}

enum ThirdPartyType {
  CUSTOMER
  SUPPLIER
  EMPLOYEE
  GOVERNMENT
  OTHER
}

enum PeriodStatus {
  OPEN
  CLOSED
  LOCKED
}

enum EntrySourceType {
  MANUAL
  IMPORT
  API
  ADJUSTMENT
  CONSOLIDATION
}

enum EntryStatus {
  DRAFT
  POSTED
  REVERSED
  VOIDED
}

enum BatchStatus {
  DRAFT
  VALIDATED
  READY_TO_POST
  POSTED
  REJECTED
}

enum ConsolidationMethod {
  FULL
  PROPORTIONAL
  EQUITY
}

enum ConsolidationRunStatus {
  DRAFT
  RUNNING
  COMPLETED
  APPROVED
  REJECTED
}

enum ConsolidationEntryType {
  AGGREGATION
  ELIMINATION
  ADJUSTMENT
  RECLASSIFICATION
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  RESTORE
  POST
  APPROVE
  LOGIN
  LOGOUT
}

model Company {
  id                 String                      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code               String                      @unique @db.VarChar(20)
  legalName          String                      @map("legal_name") @db.VarChar(200)
  taxId              String?                     @map("tax_id") @db.VarChar(50)
  countryCode        String                      @map("country_code") @db.Char(2)
  baseCurrency       CurrencyCode                @map("base_currency")
  isActive           Boolean                     @default(true) @map("is_active")
  deletedAt          DateTime?                   @map("deleted_at") @db.Timestamptz(6)
  createdAt          DateTime                    @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime                    @updatedAt @map("updated_at") @db.Timestamptz(6)
  userCompanies      UserCompany[]
  fiscalPeriods      FiscalPeriod[]
  chartAccounts      ChartAccount[]
  thirdParties       ThirdParty[]
  costCenters        CostCenter[]
  journals           Journal[]
  journalEntries     JournalEntry[]
  journalEntryLines  JournalEntryLine[]
  accountingBatches  AccountingBatch[]
  stagingEntries     StagingEntry[]
  consolidationLinks ConsolidationGroupCompany[]
  consolidationMaps  ConsolidationAccountMap[]
  sourceConsolidated ConsolidationEntry[]
  auditLogs          AuditLog[]

  @@index([isActive], map: "idx_companies_is_active")
  @@map("companies")
}

model User {
  id                 String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email              String             @unique @db.VarChar(320)
  fullName           String             @map("full_name") @db.VarChar(150)
  isActive           Boolean            @default(true) @map("is_active")
  createdAt          DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime           @updatedAt @map("updated_at") @db.Timestamptz(6)
  userCompanies      UserCompany[]
  createdEntries     JournalEntry[]     @relation("entry_created_by")
  postedEntries      JournalEntry[]     @relation("entry_posted_by")
  preparedBatches    AccountingBatch[]  @relation("batch_prepared_by")
  initiatedRuns      ConsolidationRun[] @relation("run_initiated_by")
  approvedRuns       ConsolidationRun[] @relation("run_approved_by")
  auditLogs          AuditLog[]

  @@map("users")
}

model UserCompany {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId     String   @map("user_id") @db.Uuid
  companyId  String   @map("company_id") @db.Uuid
  role       UserRole
  isActive   Boolean  @default(true) @map("is_active")
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt  DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  company    Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([userId, companyId], map: "uq_user_companies_user_company")
  @@index([companyId, role], map: "idx_user_companies_company_role")
  @@map("user_companies")
}

model FiscalPeriod {
  id          String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  companyId   String       @map("company_id") @db.Uuid
  periodName  String       @map("period_name") @db.VarChar(30)
  startDate   DateTime     @map("start_date") @db.Date
  endDate     DateTime     @map("end_date") @db.Date
  status      PeriodStatus @default(OPEN)
  lockedAt    DateTime?    @map("locked_at") @db.Timestamptz(6)
  createdAt   DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime     @updatedAt @map("updated_at") @db.Timestamptz(6)
  company     Company      @relation(fields: [companyId], references: [id], onDelete: Restrict)
  entries     JournalEntry[]

  @@unique([companyId, periodName], map: "uq_fiscal_periods_company_name")
  @@index([companyId, startDate, endDate], map: "idx_fiscal_periods_company_dates")
  @@map("fiscal_periods")
}

model ChartAccount {
  id                 String                  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  companyId          String                  @map("company_id") @db.Uuid
  parentAccountId    String?                 @map("parent_account_id") @db.Uuid
  code               String                  @db.VarChar(30)
  name               String                  @db.VarChar(150)
  accountType        AccountType             @map("account_type")
  allowsPosting      Boolean                 @default(true) @map("allows_posting")
  level              Int                     @default(1)
  isActive           Boolean                 @default(true) @map("is_active")
  deletedAt          DateTime?               @map("deleted_at") @db.Timestamptz(6)
  createdAt          DateTime                @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime                @updatedAt @map("updated_at") @db.Timestamptz(6)
  company            Company                 @relation(fields: [companyId], references: [id], onDelete: Restrict)
  parentAccount      ChartAccount?           @relation("account_hierarchy", fields: [parentAccountId], references: [id], onDelete: Restrict)
  childAccounts      ChartAccount[]          @relation("account_hierarchy")
  lines              JournalEntryLine[]
  accountMaps        ConsolidationAccountMap[]

  @@unique([companyId, code], map: "uq_chart_accounts_company_code")
  @@index([companyId, accountType], map: "idx_chart_accounts_company_type")
  @@index([parentAccountId], map: "idx_chart_accounts_parent")
  @@map("chart_accounts")
}

model ThirdParty {
  id              String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  companyId       String         @map("company_id") @db.Uuid
  code            String         @db.VarChar(40)
  name            String         @db.VarChar(150)
  thirdPartyType  ThirdPartyType @map("third_party_type")
  documentNumber  String?        @map("document_number") @db.VarChar(50)
  isActive        Boolean        @default(true) @map("is_active")
  deletedAt       DateTime?      @map("deleted_at") @db.Timestamptz(6)
  createdAt       DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime       @updatedAt @map("updated_at") @db.Timestamptz(6)
  company         Company        @relation(fields: [companyId], references: [id], onDelete: Restrict)
  lines           JournalEntryLine[]

  @@unique([companyId, code], map: "uq_third_parties_company_code")
  @@index([companyId, thirdPartyType], map: "idx_third_parties_company_type")
  @@map("third_parties")
}

model CostCenter {
  id          String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  companyId   String             @map("company_id") @db.Uuid
  code        String             @db.VarChar(30)
  name        String             @db.VarChar(120)
  isActive    Boolean            @default(true) @map("is_active")
  deletedAt   DateTime?          @map("deleted_at") @db.Timestamptz(6)
  createdAt   DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime           @updatedAt @map("updated_at") @db.Timestamptz(6)
  company     Company            @relation(fields: [companyId], references: [id], onDelete: Restrict)
  lines       JournalEntryLine[]

  @@unique([companyId, code], map: "uq_cost_centers_company_code")
  @@index([companyId, isActive], map: "idx_cost_centers_company_active")
  @@map("cost_centers")
}

model Journal {
  id          String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  companyId   String         @map("company_id") @db.Uuid
  code        String         @db.VarChar(20)
  name        String         @db.VarChar(80)
  isActive    Boolean        @default(true) @map("is_active")
  createdAt   DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime       @updatedAt @map("updated_at") @db.Timestamptz(6)
  company     Company        @relation(fields: [companyId], references: [id], onDelete: Restrict)
  entries     JournalEntry[]

  @@unique([companyId, code], map: "uq_journals_company_code")
  @@map("journals")
}

model AccountingBatch {
  id              String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  companyId       String        @map("company_id") @db.Uuid
  batchNumber     String        @map("batch_number") @db.VarChar(40)
  sourceSystem    String        @map("source_system") @db.VarChar(50)
  status          BatchStatus   @default(DRAFT)
  importedAt      DateTime?     @map("imported_at") @db.Timestamptz(6)
  validatedAt     DateTime?     @map("validated_at") @db.Timestamptz(6)
  preparedByUserId String?      @map("prepared_by_user_id") @db.Uuid
  postedEntryId   String?        @unique(map: "uq_accounting_batches_posted_entry") @map("posted_entry_id") @db.Uuid
  createdAt       DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime      @updatedAt @map("updated_at") @db.Timestamptz(6)
  company         Company       @relation(fields: [companyId], references: [id], onDelete: Restrict)
  preparedByUser  User?         @relation("batch_prepared_by", fields: [preparedByUserId], references: [id], onDelete: SetNull)
  postedEntry     JournalEntry?  @relation("batch_posted_entry", fields: [postedEntryId], references: [id], onDelete: SetNull)
  journalEntries  JournalEntry[] @relation("batch_entries")
  stagingEntries  StagingEntry[]

  @@unique([companyId, batchNumber], map: "uq_accounting_batches_company_number")
  @@index([companyId, status], map: "idx_accounting_batches_company_status")
  @@map("accounting_batches")
}

model StagingEntry {
  id              String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  companyId       String         @map("company_id") @db.Uuid
  batchId         String         @map("batch_id") @db.Uuid
  lineNo          Int            @map("line_no")
  accountCode     String         @map("account_code") @db.VarChar(30)
  thirdPartyCode  String?        @map("third_party_code") @db.VarChar(40)
  costCenterCode  String?        @map("cost_center_code") @db.VarChar(30)
  transactionDate DateTime       @map("transaction_date") @db.Date
  description     String?        @db.VarChar(250)
  debit           Decimal        @default(0) @db.Decimal(18, 2)
  credit          Decimal        @default(0) @db.Decimal(18, 2)
  currency        CurrencyCode
  isValid         Boolean        @default(false) @map("is_valid")
  validationErrors Json?         @map("validation_errors")
  createdAt       DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime       @updatedAt @map("updated_at") @db.Timestamptz(6)
  company         Company        @relation(fields: [companyId], references: [id], onDelete: Restrict)
  batch           AccountingBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)

  @@unique([batchId, lineNo], map: "uq_staging_entries_batch_line")
  @@index([companyId, isValid], map: "idx_staging_entries_company_valid")
  @@map("staging_entries")
}

model JournalEntry {
  id               String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  companyId        String           @map("company_id") @db.Uuid
  journalId        String           @map("journal_id") @db.Uuid
  periodId         String           @map("period_id") @db.Uuid
  batchId          String?          @map("batch_id") @db.Uuid
  entryNumber      Int              @map("entry_number")
  entryDate        DateTime         @map("entry_date") @db.Date
  postingDate      DateTime         @map("posting_date") @db.Date
  description      String           @db.VarChar(250)
  sourceType       EntrySourceType  @map("source_type")
  status           EntryStatus      @default(DRAFT)
  externalRef      String?          @map("external_ref") @db.VarChar(100)
  createdByUserId  String?          @map("created_by_user_id") @db.Uuid
  postedByUserId   String?          @map("posted_by_user_id") @db.Uuid
  reversedEntryId  String?          @unique(map: "uq_journal_entries_reversed_entry") @map("reversed_entry_id") @db.Uuid
  postedAt         DateTime?        @map("posted_at") @db.Timestamptz(6)
  createdAt        DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime         @updatedAt @map("updated_at") @db.Timestamptz(6)
  company          Company          @relation(fields: [companyId], references: [id], onDelete: Restrict)
  journal          Journal          @relation(fields: [journalId], references: [id], onDelete: Restrict)
  period           FiscalPeriod     @relation(fields: [periodId], references: [id], onDelete: Restrict)
  batch            AccountingBatch? @relation("batch_entries", fields: [batchId], references: [id], onDelete: SetNull)
  createdByUser    User?            @relation("entry_created_by", fields: [createdByUserId], references: [id], onDelete: SetNull)
  postedByUser     User?            @relation("entry_posted_by", fields: [postedByUserId], references: [id], onDelete: SetNull)
  reversedEntry    JournalEntry?    @relation("entry_reversal", fields: [reversedEntryId], references: [id], onDelete: SetNull)
  reversalOf       JournalEntry?    @relation("entry_reversal")
  lines            JournalEntryLine[]
  batchPosted      AccountingBatch? @relation("batch_posted_entry")

  @@unique([companyId, periodId, entryNumber], map: "uq_journal_entries_company_period_number")
  @@index([companyId, status, postingDate], map: "idx_journal_entries_company_status_posting")
  @@index([journalId, entryDate], map: "idx_journal_entries_journal_date")
